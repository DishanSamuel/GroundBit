# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ─── AWS ──────────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
S3_BUCKET=your-bucket-name

# If running on EC2 with an IAM role, leave these blank —
# the SDK will use the instance metadata service automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Meta / WhatsApp Cloud API ────────────────────────────────────────────────
# From https://developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_ID=your_phone_number_id_here
WHATSAPP_API_VERSION=v19.0

# A secret string YOU choose — paste the same value into the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=my_super_secret_verify_token
